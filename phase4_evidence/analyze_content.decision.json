{
  "is_leaf": false,
  "children": [
    {
      "id": "word_count_analyzer",
      "description": "Count the whitespace-separated words in a text body",
      "interface": {
        "operations": [
          {
            "name": "count",
            "inputs": {
              "body": "string"
            },
            "outputs": {
              "word_count": "int"
            },
            "errors": []
          }
        ]
      },
      "dependencies": [],
      "behavior": [
        {
          "id": "split_and_count",
          "prose": "Split body on whitespace (any run of whitespace is one delimiter) and return the number of resulting tokens as word_count."
        }
      ]
    },
    {
      "id": "reading_level_analyzer",
      "description": "Classify text difficulty as 'easy' or 'hard' based on average words per sentence",
      "interface": {
        "operations": [
          {
            "name": "classify",
            "inputs": {
              "body": "string"
            },
            "outputs": {
              "reading_level": "string"
            },
            "errors": []
          }
        ]
      },
      "dependencies": [],
      "behavior": [
        {
          "id": "sentence_split",
          "prose": "Split body on '.' to produce a list of sentence fragments."
        },
        {
          "id": "average_words",
          "prose": "For each fragment, count whitespace-separated words; compute the mean across all fragments."
        },
        {
          "id": "classify_level",
          "prose": "Return 'easy' if the average is strictly less than 12, otherwise return 'hard'."
        }
      ]
    },
    {
      "id": "top_keyword_analyzer",
      "description": "Find the most frequent word in a text body, with alphabetical tie-breaking",
      "interface": {
        "operations": [
          {
            "name": "find_top",
            "inputs": {
              "body": "string"
            },
            "outputs": {
              "top_keyword": "string"
            },
            "errors": []
          }
        ]
      },
      "dependencies": [],
      "behavior": [
        {
          "id": "normalize",
          "prose": "Lowercase every whitespace-separated token in body."
        },
        {
          "id": "tally",
          "prose": "Count the frequency of each normalized token."
        },
        {
          "id": "select_top",
          "prose": "Return the token with the highest frequency. Break ties by selecting the lexicographically earliest word."
        }
      ]
    },
    {
      "id": "has_links_checker",
      "description": "Detect whether a text body contains any URL by checking for the substring 'http'",
      "interface": {
        "operations": [
          {
            "name": "check",
            "inputs": {
              "body": "string"
            },
            "outputs": {
              "has_links": "bool"
            },
            "errors": []
          }
        ]
      },
      "dependencies": [],
      "behavior": [
        {
          "id": "substring_check",
          "prose": "Return true if the literal substring 'http' appears anywhere in body (case-sensitive), false otherwise."
        }
      ]
    },
    {
      "id": "analysis_assembler",
      "description": "Combine the four sub-analysis results into a single analysis dict",
      "interface": {
        "operations": [
          {
            "name": "assemble",
            "inputs": {
              "word_count": "int",
              "reading_level": "string",
              "top_keyword": "string",
              "has_links": "bool"
            },
            "outputs": {
              "analysis": "dict"
            },
            "errors": []
          }
        ]
      },
      "dependencies": [
        "word_count_analyzer",
        "reading_level_analyzer",
        "top_keyword_analyzer",
        "has_links_checker"
      ],
      "behavior": [
        {
          "id": "build_dict",
          "prose": "Return a dict with exactly four keys \u2014 word_count, reading_level, top_keyword, has_links \u2014 populated from the corresponding injected inputs."
        }
      ]
    }
  ],
  "edges": [
    {
      "from": "word_count_analyzer",
      "to": "analysis_assembler",
      "name": "word_count"
    },
    {
      "from": "reading_level_analyzer",
      "to": "analysis_assembler",
      "name": "reading_level"
    },
    {
      "from": "top_keyword_analyzer",
      "to": "analysis_assembler",
      "name": "top_keyword"
    },
    {
      "from": "has_links_checker",
      "to": "analysis_assembler",
      "name": "has_links"
    }
  ]
}